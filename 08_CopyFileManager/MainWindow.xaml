<Window x:Class="_08_CopyFileManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_08_CopyFileManager"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Grid Margin="5" DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label FontSize="20" FontWeight="Black">From :</Label>
            <TextBox Grid.Column="1" 
              Margin="5" 
              Padding="10" Name="srcTb"></TextBox>
            <Button Grid.Column="2" Padding="10" Margin="5"
                    Click="SourceButton_Click">Browse</Button>

            <Label Grid.Row="1" FontSize="20" FontWeight="Black">To:</Label>
            <TextBox Grid.Column="1" Grid.Row="1"  Name="destTb" 
              Margin="5" 
              Padding="10"></TextBox>
            <Button Grid.Column="2" 
             Grid.Row="1" 
             Padding="10"
             Margin="5" Click="DestButton_Click_1">Browse</Button>
            <Button Grid.Row="2" Grid.ColumnSpan="3" FontSize="20"
             FontWeight="Black" Click="CopyButton_Click" >Copy</Button>
        </Grid>

        <ProgressBar IsIndeterminate="True" DockPanel.Dock="Bottom"
                     Height="20"></ProgressBar>
        <ListBox x:Name="listFiles" ></ListBox>
        
    </DockPanel>
   
</Window>
